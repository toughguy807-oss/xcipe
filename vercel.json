{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "public",
  "framework": null,
  "trailingSlash": false,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://REPLACE_WITH_RAILWAY_DOMAIN.up.railway.app/api/:path*"
    },
    {
      "source": "/static/output/:path*",
      "destination": "https://REPLACE_WITH_RAILWAY_DOMAIN.up.railway.app/static/output/:path*"
    },
    {
      "source": "/bridge/:path*",
      "destination": "https://REPLACE_WITH_RAILWAY_DOMAIN.up.railway.app/bridge/:path*"
    },
    {
      "source": "/((?!api|static|bridge|_next|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*\\.(?:js|css|woff2|woff|ttf|otf|png|jpg|jpeg|gif|svg|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
