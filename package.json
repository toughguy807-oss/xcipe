{
  "name": "eluo-sys",
  "version": "4.0.0",
  "description": "Web-based Digital Agency Automation Platform",
  "main": "src/server.js",
  "bin": {
    "xcipe-worker": "bin/xcipe-worker.js"
  },
  "scripts": {
    "prestart": "node scripts/bundle-claude.js",
    "start": "node src/server.js",
    "start:strict": "node scripts/bundle-claude.js --check && node src/server.js",
    "start:queue-only": "WORKER_MODE=queue-only node src/server.js",
    "start:with-kds": "concurrently -n xcipe,kds-bridge -c blue,green \"node src/server.js\" \"node kds-v4/bridge-server.js\"",
    "worker": "node bin/xcipe-worker.js",
    "kds-bridge": "node kds-v4/bridge-server.js",
    "dev": "ESYS_DEV=1 node --watch src/server.js",
    "dev:bundle": "node --watch src/server.js",
    "dev:nodemon": "nodemon --watch src --ext js,json --exec \"node src/server.js\"",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "bundle:claude": "node scripts/bundle-claude.js",
    "bundle:dry": "node scripts/bundle-claude.js --dry",
    "bundle:check": "node scripts/bundle-claude.js --check",
    "prebuild": "node scripts/bundle-claude.js",
    "verify:xcipe": "node scripts/verify-xcipe.js",
    "verify:xcipe:json": "node scripts/verify-xcipe.js --json",
    "audit:isolation": "node scripts/audit-isolation.js",
    "audit:isolation:strict": "node scripts/audit-isolation.js --strict",
    "audit:skills": "node scripts/audit-skills.js",
    "audit:all": "node scripts/audit-isolation.js && node scripts/audit-skills.js",
    "test": "node --test --test-reporter=spec",
    "test:smoke": "node --test --test-reporter=spec tests/smoke/modules.test.js",
    "test:unit": "node --test --test-reporter=spec tests/unit/db-pricing.test.js tests/unit/rate-limit.test.js"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^3.6.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "marked": "^15.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.4",
    "pdf-poppler": "^0.2.3",
    "playwright": "^1.59.1",
    "puppeteer": "^24.40.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^11.0.0"
  }
}
