{
  "version": "1.0",
  "introduced": "2026-04-30",
  "policy": "lib/rules/dkb-policy.md",

  "thresholds": {
    "tier_1_min": 145,
    "tier_2_min": 110,
    "archive_max": 109,
    "design_replicate_pass": 145,
    "design_replicate_conditional": 130,
    "max_score": 180
  },

  "automation": {
    "dkb_harvest": "disabled",
    "dkb_analyze": "manual_trigger",
    "trend_radar": "manual_trigger",
    "dkb_search": "auto"
  },

  "vision_llm": {
    "model": "claude-sonnet-4-6",
    "max_tokens_per_site": 12000,
    "screenshots_per_site": 2,
    "breakpoints": [375, 1440],
    "cache_system_prompt": true,
    "rationale": "Gemini 금지, Claude-only 정책 (lib/rules/dkb-policy.md §4)"
  },

  "rubric": {
    "version": "v1",
    "axes_count": 18,
    "rubric_path": "dkb/aesthetic-rubric-v1.md",
    "korean_b2b_axes": ["L2-3", "L3-4", "L3-5", "L3-6"],
    "award_axes": ["L3-7", "L3-8"]
  },

  "korean_b2b_weight_multiplier": 1.5,
  "ccd_user_gate_threshold_attempts": 3,

  "regeneration": {
    "max_attempts": 3,
    "first_retry": "different_references",
    "second_retry": "weakest_axis_strengthen",
    "third_retry": "user_escalation"
  },

  "industries": {
    "industrial-ai": {
      "tier_priority": ["tier-2"],
      "examples": ["augury.com", "scale.com", "landing.ai", "c3.ai"]
    },
    "frontier-ai": {
      "tier_priority": ["tier-1"],
      "examples": ["anthropic.com", "openai.com", "cohere.com"]
    },
    "b2b-saas": {
      "tier_priority": ["tier-1"],
      "examples": ["linear.app", "vercel.com", "stripe.com", "notion.so"]
    },
    "korea-b2b": {
      "tier_priority": ["tier-3"],
      "examples": ["toss.tech", "line.me", "woowahan.com"]
    },
    "manufacturing-korea": {
      "tier_priority": ["tier-3", "tier-2"],
      "examples": ["makinarocks.ai", "augury.com"]
    }
  },

