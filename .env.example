# ELUO XCIPE v4.0 — 환경변수 명세
# Railway 환경에 직접 입력하거나 `railway variables set KEY=VALUE` 사용
# 로컬 개발은 .env (gitignore 됨) 로 복사

# ── 런타임 ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3747

# ── DB ─────────────────────────────────────────────────────────────────
# Railway Volume 마운트 경로 (기본값: /app/data/eluo.db)
# 로컬 개발 시: ./data/eluo.db
DB_PATH=/app/data/eluo.db

# ── 인증 (JWT) ─────────────────────────────────────────────────────────
# 반드시 32바이트 이상 랜덤 시크릿. 생성: `openssl rand -hex 32`
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_HEX

# 초기 관리자 (서버 첫 부팅 시 자동 생성)
ADMIN_EMAIL=admin@eluocnc.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── CORS ───────────────────────────────────────────────────────────────
# Vercel 프론트 도메인 (배포 후 입력)
# 예: https://xcipe.vercel.app,https://xcipe.eluocnc.com
CORS_ORIGIN=*

# ── AI Provider (DB settings 로 관리 — 환경변수 아님) ────────────────
# 첫 부팅 시 db.js:1256 에 의해 ai_provider='mock' 으로 자동 시드.
# 변경: /api/admin/settings 또는 admin 콘솔에서 'mock' | 'claude-code' | 'claude-api'
#   mock        : Railway 기본. 가짜 응답. UI/티켓/대시보드/관리만 노출.
#   claude-api  : ANTHROPIC_API_KEY 필요. 클라우드에서 실제 호출. 비용 발생.
#   claude-code : 로컬 PC 전용. ~/.claude OAuth 토큰 의존이라 컨테이너 불가.

# ── Anthropic API (claude-api 모드 선택 시에만 필요) ─────────────────
# Railway 기본은 mock 이므로 비워두면 됨.
# (현재 운영: 로컬 PC = claude-code 실행, Railway = mock 게이트웨이)
ANTHROPIC_API_KEY=

# ── KDS bridge (v25 통합) ─────────────────────────────────────────────
# kds-v4 폴더 위치. Railway 컨테이너는 /app/kds-v4 (Dockerfile 에서 자동 세팅).
# 로컬 개발 시 다른 경로면 override.
KDS_V4_ROOT=/app/kds-v4

# kds-bridge 내부 포트 (외부 노출 X, xcipe Express 가 /kds-bridge/* 로 proxy).
KDS_BRIDGE_PORT=3939

# Figma 플러그인 인증 (선택). 미설정 시 dev open 모드.
FIGMA_PLUGIN_TOKEN=

# 외부에 노출되는 base URL (preview URL 절대경로 생성용). Vercel 도메인 또는 Railway 도메인.
# 미설정 시 상대경로 사용 (브라우저가 현재 도메인 기준).
PUBLIC_BASE_URL=

# ── 외부 통합 (선택) ───────────────────────────────────────────────────
GEMINI_API_KEY=
FIGMA_ACCESS_TOKEN=

# ── Supabase (Storage 사용 시 — Phase 2 예정) ──────────────────────────
# 현재는 Railway Volume(output/)에 직접 저장. 향후 마이그레이션 시 활성화.
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_STORAGE_BUCKET=xcipe-output

# ── 운영 옵션 ──────────────────────────────────────────────────────────
# express trust proxy (Railway 는 reverse proxy 뒤에 있음)
TRUST_PROXY=1

# 산출물 정적 서빙 토큰 만료 (분)
STATIC_TOKEN_TTL_MIN=60
