# ELUO XCIPE v4.0 — 환경변수 명세
# Railway 환경에 직접 입력하거나 `railway variables set KEY=VALUE` 사용
# 로컬 개발은 .env (gitignore 됨) 로 복사

# ── 런타임 ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3747

# ── DB ─────────────────────────────────────────────────────────────────
# Railway Volume 마운트 경로 (기본값: /app/data/eluo.db)
# 로컬 개발 시: ./data/eluo.db
DB_PATH=/app/data/eluo.db

# ── 인증 (JWT) ─────────────────────────────────────────────────────────
# 반드시 32바이트 이상 랜덤 시크릿. 생성: `openssl rand -hex 32`
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_HEX

# 초기 관리자 (서버 첫 부팅 시 자동 생성)
ADMIN_EMAIL=admin@eluocnc.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── CORS ───────────────────────────────────────────────────────────────
# Vercel 프론트 도메인 (배포 후 입력)
# 예: https://xcipe.vercel.app,https://xcipe.eluocnc.com
CORS_ORIGIN=*

# ── Anthropic / Claude ─────────────────────────────────────────────────
# 파이프라인 실행 시 필요. 미수급 상태면 비워두고 UI/관리 기능만 사용
ANTHROPIC_API_KEY=

# ── 외부 통합 (선택) ───────────────────────────────────────────────────
GEMINI_API_KEY=
FIGMA_ACCESS_TOKEN=

# ── Supabase (Storage 사용 시 — Phase 2 예정) ──────────────────────────
# 현재는 Railway Volume(output/)에 직접 저장. 향후 마이그레이션 시 활성화.
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_STORAGE_BUCKET=xcipe-output

# ── 운영 옵션 ──────────────────────────────────────────────────────────
# express trust proxy (Railway 는 reverse proxy 뒤에 있음)
TRUST_PROXY=1

# 산출물 정적 서빙 토큰 만료 (분)
STATIC_TOKEN_TTL_MIN=60
