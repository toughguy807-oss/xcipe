{
  "$schema": "../spec.schema.json",
  "name": "data-visual",
  "version": "1.0",
  "source": "kds/data/components/data-visual/01~18.jpg",
  "description": "정량적 데이터를 시각적으로 표현하여 빠르게 패턴, 추세, 비교를 이해할 수 있습니다.",

  "anatomy": [
    { "id": 1, "name": "Title",          "required": true },
    { "id": 2, "name": "Dropdown",       "required": false, "note": "기간/필터 선택 (예: '8월')" },
    { "id": 3, "name": "Chart Contents", "required": true,  "note": "그래프 본문" },
    { "id": 4, "name": "Legend",         "required": false, "note": "데이터 시리즈 색·이름" }
  ],

  "variants": {
    "type": {
      "values": ["bar", "pie", "donut", "line"],
      "default": "bar",
      "spec": "data-visual/07"
    },
    "barSubtype": {
      "values": ["vertical", "horizontal", "dual", "stacked"],
      "appliesTo": ["bar"],
      "spec": "data-visual/08, 09"
    },
    "lineSubtype": {
      "values": ["straight", "curved", "straight-fill", "curved-fill"],
      "appliesTo": ["line"],
      "spec": "data-visual/13, 14"
    },
    "palette": {
      "values": ["default", "light", "strong", "extended", "sequential"],
      "default": "default",
      "spec": "data-visual/02~06"
    }
  },

  "colorPalettes": {
    "spec": "data-visual/02~06",
    "default":    { "tokens": ["teal.400", "yellow.400", "blue.400", "purple.400", "red.400"],         "note": "범주 구분 명확, 강조 필요한 항목" },
    "light":      { "tokens": ["teal.300", "yellow.300", "blue.300", "purple.300", "red.300"],         "note": "다수 항목 부드러운 구분" },
    "strong":     { "tokens": ["teal.500", "yellow.300", "blue.300", "purple.300", "red.300"],         "note": "특정 데이터 강조 (Teal 500 1개만 진하게)" },
    "extended":   { "tokens": ["olive.400", "navy.400", "magenta.400", "green.400", "lemon.400"],      "note": "범주 세분화, default 와 함께 사용" },
    "sequential": { "tokens": ["teal.800", "teal.700", "teal.600", "teal.500", "teal.400", "teal.300", "teal.200", "teal.100"], "note": "값 크기·흐름 명도 단계" }
  },

  "sizes": {
    "spec": "data-visual/07, 12",
    "tokens": {
      "Fixed": { "minHeight": 400, "note": "Bar/Line 차트 컨테이너 height" },
      "Donut": { "innerRadius": 0.65, "outerRadius": 1.0, "note": "Donut 차트 inner radius 비율" }
    }
  },

  "colorMatrix": {
    "spec": "data-visual/07",
    "default": {
      "title":      "text.primary",
      "axis":       "text.tertiary-01",
      "gridLine":   "border.tertiary-01",
      "legend":     "text.secondary-01",
      "background": "background.default"
    }
  },

  "legend": {
    "spec": "data-visual/04, 15",
    "position": ["bottom", "right"],
    "hideable": {
      "spec": "data-visual/15",
      "note": "범례 많을 때 범례 보기 dropdown 사용 (체크박스 형태 + 표시 토글)"
    }
  },

  "interactions": {
    "spec": "data-visual/16",
    "emphasized": {
      "note": "Strong palette 로 특정 시리즈 강조. 클릭/포커스 시 다른 시리즈 dim"
    }
  },

  "rules": [
    {
      "id": "bar-max-5",
      "severity": "warning",
      "spec": "data-visual/17",
      "do": "Bar chart 는 최대 5개의 데이터만 표시합니다.",
      "dont": "데이터가 6개 이상인 경우 다른 차트 유형을 고려합니다.",
      "maxItems": 5
    },
    {
      "id": "donut-max-8",
      "severity": "warning",
      "spec": "data-visual/18",
      "do": "도넛/파이 차트는 최대 8개의 데이터만 표시합니다.",
      "dont": "데이터가 8개 이상인 경우 7개까지만 표시하고 나머지는 '기타'로 합쳐 표시합니다.",
      "maxItems": 8
    },
    {
      "id": "donut-largest-to-smallest",
      "severity": "info",
      "spec": "data-visual/11",
      "do": "도넛 차트는 주로 가장 큰 값에서 가장 작은 값 순으로 배치합니다."
    }
  ],

  "lintHints": {
    "componentNameKeywords": ["chart", "graph", "data-visual", "bar-chart", "pie-chart", "donut-chart", "line-chart"]
  }
}
