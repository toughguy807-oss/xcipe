{
  "$schema": "../spec.schema.json",
  "name": "divider",
  "version": "1.0",
  "source": "kds/data/components/divider/01~04.jpg",
  "description": "정보 그룹 간의 계층과 관계를 명확히 구분합니다.",

  "anatomy": [
    { "id": 1, "name": "Inset Divider",      "required": false, "note": "콘텐츠 내부 1px 라인" },
    { "id": 2, "name": "Full Width Divider", "required": false, "note": "화면 전체 폭 8px 갭" }
  ],

  "variants": {
    "type": {
      "values": ["inset", "full-width"],
      "default": "inset",
      "spec": "divider/02, 03",
      "note": "inset=리스트 항목 사이 얇은 라인. full-width=섹션 단위 큰 그룹 구분"
    }
  },

  "sizes": {
    "spec": "divider/04",
    "tokens": {
      "Inset":     { "height": 1, "sidePadding": 20 },
      "FullWidth": { "height": 8, "sidePadding": 0 }
    },
    "default": "Inset"
  },

  "colorMatrix": {
    "spec": "divider/04",
    "inset":      { "stroke": "border.tertiary-01" },
    "full-width": { "fill":   "fill.disabled-01" }
  },

  "placement": {
    "spec": "divider/02, 03",
    "inset": {
      "context": ["list-item", "setting-menu-item"],
      "note": "list-item 사이에 1px"
    },
    "full-width": {
      "context": ["section-break", "between-cards"],
      "note": "큰 단위 섹션 사이에 8px 회색 갭"
    }
  },

  "lintHints": {
    "componentNameKeywords": ["divider", "separator", "hr"]
  }
}
