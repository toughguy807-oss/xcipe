{
  "$schema": "../spec.schema.json",
  "name": "chip",
  "version": "1.0",
  "source": "kds/data/components/chip/01~10.jpg",
  "description": "항목을 선택하거나 상태를 표시할 수 있습니다.",

  "anatomy": [
    { "id": 1, "name": "Container", "required": true },
    { "id": 2, "name": "Label",     "required": true },
    { "id": 3, "name": "Icon",      "required": false, "note": "Filter=chevron-down, Input=close-x" }
  ],

  "variants": {
    "type": {
      "values": ["select", "filter", "input"],
      "default": "select",
      "spec": "chip/02, 03, 04, 05",
      "note": "select=라벨만, filter=라벨+chevron(선택 옵션), input=라벨+X(제거 가능)"
    },
    "selected": {
      "values": ["unselected", "selected"],
      "default": "unselected",
      "spec": "chip/06"
    },
    "state": {
      "values": ["default", "hover", "pressed", "disabled"],
      "default": "default",
      "spec": "chip/06",
      "note": "hover 는 PC only"
    },
    "group": {
      "values": ["inline", "collapsed", "expanded"],
      "default": "inline",
      "spec": "chip/09",
      "note": "collapsed/expanded 는 Folder chip group (펼침/접힘)"
    }
  },

  "sizes": {
    "spec": "chip/07",
    "tokens": {
      "Default": { "height": 36 }
    },
    "default": "Default"
  },

  "padding": {
    "spec": "chip/07",
    "select": { "left": 12, "right": 12 },
    "filter": { "left": 12, "iconGap": 1, "right": 10 },
    "input":  { "left": 12, "iconGap": 1, "right": 10 }
  },

  "placement": {
    "spec": "chip/07",
    "gap": { "horizontal": 8, "vertical": 6 }
  },

  "width": {
    "spec": "chip/08",
    "policies": {
      "flexible": { "description": "레이블 길이에 맞춰 자연 폭", "maxLabel": "최대 열 네 자 권장" }
    }
  },

  "colorMatrix": {
    "spec": "chip/06",
    "unselected": {
      "default":  { "fill": "fill.secondary-01",         "label": "text.primary",      "icon": "icon.primary" },
      "hover":    { "fill": "fill.secondary-hover-01",   "label": "text.primary",      "icon": "icon.primary" },
      "pressed":  { "fill": "fill.secondary-pressed-01", "label": "text.primary",      "icon": "icon.primary" },
      "disabled": { "fill": "fill.disabled-01",          "label": "text.disabled-01",  "icon": "icon.disabled-01" }
    },
    "selected": {
      "default":  { "fill": "fill.primary",         "label": "text.inverse", "icon": "icon.inverse" },
      "hover":    { "fill": "fill.primary-hover",   "label": "text.inverse", "icon": "icon.inverse" },
      "pressed":  { "fill": "fill.primary-pressed", "label": "text.inverse", "icon": "icon.inverse" },
      "disabled": { "fill": "fill.disabled-01",     "label": "text.disabled-01", "icon": "icon.disabled-01" }
    }
  },

  "radius": {
    "default": "radius.circle",
    "note": "pill 형태 — Figma 에서 height/2 또는 radius.circle (999)"
  },

  "rules": [
    {
      "id": "horizontal-scroll-many",
      "severity": "warning",
      "spec": "chip/10",
      "do": "항목이 많을 경우 가로 스크롤을 적용합니다.",
      "dont": "잘려서 보이지 않게 하거나 줄바꿈만으로 처리하지 않습니다."
    },
    {
      "id": "no-single-chip",
      "severity": "warning",
      "spec": "chip/10",
      "do": "항목이 2개 이상일 때 칩을 사용합니다.",
      "dont": "항목이 하나일 때는 칩을 사용하지 않습니다."
    }
  ],

  "lintHints": {
    "heightTokenSet": [36],
    "componentNameKeywords": ["chip", "filter-chip", "select-chip", "input-chip"]
  }
}
