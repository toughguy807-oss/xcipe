{
  "$schema": "../spec.schema.json",
  "name": "list",
  "version": "1.0",
  "source": "kds/data/components/list/01~12.jpg",
  "description": "정보를 한눈에 살펴볼 수 있도록 구조화된 형태로 제공합니다.",

  "anatomy": [
    { "id": 1, "name": "Container",        "required": true },
    { "id": 2, "name": "Headline",         "required": true,  "note": "주 텍스트 (좌측)" },
    { "id": 3, "name": "Trailing Element", "required": false, "note": "우측 요소 — chevron / switch / value text / button / image 등" }
  ],

  "variants": {
    "type": {
      "values": ["text", "image", "product", "menu"],
      "default": "text",
      "spec": "list/01, 02, 03, 09, 10, 11",
      "note": "text=텍스트만, image=좌측 이미지(원형/사각), product=상품 카드형, menu=설정 메뉴/펼침형"
    },
    "textItem": {
      "values": ["text", "text-with-value", "text-with-switch", "text-with-button", "depth-list"],
      "appliesTo": ["text", "menu"],
      "spec": "list/03",
      "note": "depth-list 는 펼침형 — 하위 항목 들여쓰기"
    },
    "imageShape": {
      "values": ["logo-circle", "image-square"],
      "appliesTo": ["image"],
      "spec": "list/05",
      "note": "logo=원형(브랜드 로고), image=정사각 라운드"
    },
    "productLayout": {
      "values": ["one-column", "two-column"],
      "appliesTo": ["product"],
      "spec": "list/07",
      "note": "one-column=가로 1열 (이미지 + 정보 좌우), two-column=그리드 2열"
    }
  },

  "rowSpec": {
    "spec": "list/02, 04, 09",
    "textRow":      { "verticalPadding": 16, "horizontalPadding": 20, "minHeight": 56 },
    "imageRow":     { "verticalPadding": 12, "horizontalPadding": 20, "minHeight": 80,  "imageSize": 56, "imageGap": 16 },
    "menuRow":      { "verticalPadding": 16, "horizontalPadding": 20, "minHeight": 56 },
    "menuChildRow": { "verticalPadding": 12, "horizontalPadding": 32, "minHeight": 48, "indent": 12, "note": "depth-list 자식 — 좌측 들여쓰기" }
  },

  "colorMatrix": {
    "spec": "list/02, 04",
    "default": {
      "fill":     "background.default",
      "headline": "text.primary",
      "value":    "text.tertiary-01",
      "icon":     "icon.primary",
      "divider":  "border.tertiary-01"
    },
    "depthChild": {
      "fill":     "fill.secondary-01",
      "note":     "펼침 영역 자식은 옅은 회색 배경"
    }
  },

  "divider": {
    "spec": "list/02",
    "useCase": "row-between",
    "type": "inset",
    "note": "리스트 row 사이는 inset divider (좌우 20 padding) 사용"
  },

  "trailingElements": {
    "spec": "list/03",
    "values": ["none", "chevron-right", "chevron-down", "switch", "value-text", "value-text-chevron", "button"]
  },

  "lintHints": {
    "componentNameKeywords": ["list", "list-item", "row-item", "menu-list"]
  }
}
